# Copy this file to .env and fill in your values
# Or copy .env from sellermate_naver_rank_1 / sellermate_naver_place if using same DB

SUPABASE_URL=https://your-project.supabase.co
# 새 API 키 (sb_secret_...) — Legacy JWT 키 비활성화 프로젝트용
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-anon-key

# Optional: IP rotation (adb | adapter | auto | disabled)
# IP_ROTATION_METHOD=auto

# Coupang: without phone tethering/ADB, unified runner skips Coupang only (shopping/place continue on PC IP)
# Dev only — force Coupang without tethering:
# COUPANG_SKIP_TETHERING_CHECK=1

# --- 다중 PC (예: 10대) ---
# 별도 설정 없이 각 PC에서 EXE 또는 start-remote.bat 만 실행하면 됩니다.
# PC_ID = 컴퓨터 이름 (자동). 큐에서 assigned_to 로 1건씩 나눠 가짐.
# 한 PC에서 여러 건: CLAIM_LIMIT=2  BATCH_SIZE=2  (기본은 1)

# Optional: Naver login for shopping-traffic unified-runner
# NAVER_LOGIN_ENABLED=1
# NAVER_ACCOUNT_WORKBOOK=./총 취합 1353개 (3).xlsx
# NAVER_ACCOUNT_ROW_START=7
# NAVER_ACCOUNT_ROW_END=10
# NAVER_LOGIN_ID=your-naver-id
# NAVER_LOGIN_PW=your-naver-password
